<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Athenaeum — Library Records</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..900&family=Inter:wght@400;500;600;700&family=Special+Elite&display=swap" rel="stylesheet"> -->

    <style>
        :root{
            --paper:#F2EDE3;
            --card:#FBF8F0;
            --ink:#2B2620;
            --ink-soft:#6B6254;
            --green:#2F4F3E;
            --green-dark:#1E3527;
            --green-pale:#E1E9E1;
            --brass:#B8862E;
            --brass-dark:#8F6A1E;
            --brass-pale:#F1E2C2;
            --stamp-red:#8C3B33;
            --rule: rgba(43,38,32,.18);
            --shadow: 0 14px 34px -16px rgba(43,38,32,.45);
        }
        *{ box-sizing:border-box; }
        html{ -webkit-text-size-adjust:100%; }
        body{
            margin:0; min-height:100vh;
            background-color:var(--paper);
            background-image: radial-gradient(circle at 1px 1px, rgba(43,38,32,.06) 1px, transparent 0);
            background-size: 20px 20px;
            color:var(--ink);
            font-family:'Inter',-apple-system,sans-serif;
            -webkit-font-smoothing:antialiased;
            line-height:1.5;
        }
        h1,h2,h3{ font-family:'Fraunces','Georgia',serif; margin:0; color:var(--ink); }
        a{ color:inherit; }
        .wrap{ max-width:880px; margin:0 auto; padding:0 24px 80px; }

        .shelf-strip{ display:flex; align-items:flex-end; gap:5px; height:30px; padding:0 18px; overflow:hidden; border-bottom:3px solid var(--ink); }
        .shelf-strip span{ display:block; width:9px; border-radius:2px 2px 0 0; }
        .shelf-strip span:nth-child(odd){ background:var(--green); }
        .shelf-strip span:nth-child(even){ background:var(--brass); }
        .shelf-strip span:nth-child(5n){ background:var(--stamp-red); }
        .shelf-strip span:nth-child(1){ height:55%; } .shelf-strip span:nth-child(2){ height:90%; }
        .shelf-strip span:nth-child(3){ height:70%; } .shelf-strip span:nth-child(4){ height:100%; }
        .shelf-strip span:nth-child(5){ height:60%; } .shelf-strip span:nth-child(6){ height:80%; }
        .shelf-strip span:nth-child(7){ height:65%; } .shelf-strip span:nth-child(8){ height:95%; }
        .shelf-strip span:nth-child(9){ height:50%; } .shelf-strip span:nth-child(10){ height:85%; }
        .shelf-strip span:nth-child(11){ height:72%; } .shelf-strip span:nth-child(12){ height:60%; }
        .shelf-strip span:nth-child(13){ height:92%; } .shelf-strip span:nth-child(14){ height:68%; }
        .shelf-strip span:nth-child(15){ height:78%; } .shelf-strip span:nth-child(16){ height:55%; }
        .shelf-strip span:nth-child(17){ height:88%; } .shelf-strip span:nth-child(18){ height:62%; }
        .shelf-strip span:nth-child(19){ height:96%; } .shelf-strip span:nth-child(20){ height:58%; }

        .stamp{ display:inline-flex; align-items:center; font-family:'Special Elite',monospace; font-size:.7rem; letter-spacing:.08em; text-transform:uppercase; padding:6px 11px; border:1.5px solid currentColor; border-radius:3px; transform:rotate(-2deg); white-space:nowrap; }
        .stamp--green{ color:var(--green); } .stamp--brass{ color:var(--brass-dark); } .stamp--red{ color:var(--stamp-red); }

        .btn{ font-family:'Special Elite',monospace; text-transform:uppercase; letter-spacing:.04em; font-size:.82rem; display:inline-flex; align-items:center; gap:8px; padding:13px 22px; border-radius:4px; border:2px solid var(--ink); background:var(--green); color:var(--card); cursor:pointer; text-decoration:none; box-shadow:3px 3px 0 var(--ink); transition:transform .15s ease, box-shadow .15s ease; }
        .btn:hover{ transform:translate(-2px,-2px); box-shadow:5px 5px 0 var(--ink); }
        .btn:active{ transform:translate(0,0); box-shadow:1px 1px 0 var(--ink); }
        .btn:focus-visible{ outline:3px solid var(--brass); outline-offset:3px; }
        .btn--ghost{ background:var(--card); color:var(--ink); }

        .hero{ padding:64px 0 40px; text-align:center; }
        .hero .stamp{ margin-bottom:22px; }
        .hero h1{ font-size:clamp(3rem, 9vw, 5.2rem); font-weight:900; font-style:italic; letter-spacing:-.01em; margin:0 0 18px; }
        .hero p{ font-size:1.05rem; color:var(--ink-soft); max-width:46ch; margin:0 auto 36px; }
        .hero__actions{ display:flex; gap:16px; justify-content:center; flex-wrap:wrap; }

        footer.page-footer{ text-align:center; padding:30px 0 10px; color:var(--ink-soft); font-size:.8rem; }

        @media (max-width: 600px){ .wrap{ padding:0 18px 60px; } .hero{ padding:46px 0 30px; } }
        @media (prefers-reduced-motion: reduce){ *{ animation-duration:0.001ms !important; transition-duration:0.001ms !important; } }
    </style>
</head>
<body>

    <div class="shelf-strip" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="wrap">
        <header class="hero">
            <span class="stamp stamp--brass">Accessions Ledger</span>
            <h1>Athenaeum</h1>
            <p>Every title that enters this collection gets a line in the ledger — author, category, price, and how many copies are on the shelf.</p>
            <div class="hero__actions">
                <a class="btn" href="/getdata">Browse the Shelves</a>
                <a class="btn btn--ghost" href="/insertdata">Add a Title</a>
            </div>
        </header>
    </div>

    <footer class="page-footer">Athenaeum &middot; a small ledger for a growing shelf</footer>

</body>
</html>
