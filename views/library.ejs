<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>On the Shelves — Athenaeum</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..900&family=Inter:wght@400;500;600;700&family=Special+Elite&display=swap" rel="stylesheet">

    <style>
        :root{
            --paper:#F2EDE3; --card:#FBF8F0; --ink:#2B2620; --ink-soft:#6B6254;
            --green:#2F4F3E; --green-dark:#1E3527; --brass:#B8862E; --brass-dark:#8F6A1E;
            --brass-pale:#F1E2C2; --stamp-red:#8C3B33; --rule: rgba(43,38,32,.18);
            --shadow: 0 14px 34px -16px rgba(43,38,32,.45);
        }
        *{ box-sizing:border-box; }
        body{
            margin:0; min-height:100vh; background-color:var(--paper);
            background-image: radial-gradient(circle at 1px 1px, rgba(43,38,32,.06) 1px, transparent 0);
            background-size: 20px 20px; color:var(--ink);
            font-family:'Inter',-apple-system,sans-serif; -webkit-font-smoothing:antialiased; line-height:1.5;
        }
        h1,h2,h3{ font-family:'Fraunces','Georgia',serif; margin:0; color:var(--ink); }
        a{ color:inherit; }
        .wrap{ max-width:880px; margin:0 auto; padding:0 24px 80px; }

        .shelf-strip{ display:flex; align-items:flex-end; gap:5px; height:30px; padding:0 18px; overflow:hidden; border-bottom:3px solid var(--ink); }
        .shelf-strip span{ display:block; width:9px; border-radius:2px 2px 0 0; }
        .shelf-strip span:nth-child(odd){ background:var(--green); }
        .shelf-strip span:nth-child(even){ background:var(--brass); }
        .shelf-strip span:nth-child(5n){ background:var(--stamp-red); }
        .shelf-strip span:nth-child(1){ height:55%; } .shelf-strip span:nth-child(2){ height:90%; }
        .shelf-strip span:nth-child(3){ height:70%; } .shelf-strip span:nth-child(4){ height:100%; }
        .shelf-strip span:nth-child(5){ height:60%; } .shelf-strip span:nth-child(6){ height:80%; }
        .shelf-strip span:nth-child(7){ height:65%; } .shelf-strip span:nth-child(8){ height:95%; }
        .shelf-strip span:nth-child(9){ height:50%; } .shelf-strip span:nth-child(10){ height:85%; }
        .shelf-strip span:nth-child(11){ height:72%; } .shelf-strip span:nth-child(12){ height:60%; }
        .shelf-strip span:nth-child(13){ height:92%; } .shelf-strip span:nth-child(14){ height:68%; }
        .shelf-strip span:nth-child(15){ height:78%; } .shelf-strip span:nth-child(16){ height:55%; }
        .shelf-strip span:nth-child(17){ height:88%; } .shelf-strip span:nth-child(18){ height:62%; }
        .shelf-strip span:nth-child(19){ height:96%; } .shelf-strip span:nth-child(20){ height:58%; }

        .stamp{ display:inline-flex; align-items:center; font-family:'Special Elite',monospace; font-size:.7rem; letter-spacing:.08em; text-transform:uppercase; padding:6px 11px; border:1.5px solid currentColor; border-radius:3px; transform:rotate(-2deg); white-space:nowrap; }
        .stamp--green{ color:var(--green); } .stamp--brass{ color:var(--brass-dark); } .stamp--red{ color:var(--stamp-red); }

        .btn{ font-family:'Special Elite',monospace; text-transform:uppercase; letter-spacing:.04em; font-size:.82rem; display:inline-flex; align-items:center; gap:8px; padding:13px 22px; border-radius:4px; border:2px solid var(--ink); background:var(--green); color:var(--card); cursor:pointer; text-decoration:none; box-shadow:3px 3px 0 var(--ink); transition:transform .15s ease, box-shadow .15s ease; }
        .btn:hover{ transform:translate(-2px,-2px); box-shadow:5px 5px 0 var(--ink); }
        .btn:active{ transform:translate(0,0); box-shadow:1px 1px 0 var(--ink); }
        .btn:focus-visible{ outline:3px solid var(--brass); outline-offset:3px; }
        .btn--ghost{ background:var(--card); color:var(--ink); }
        .btn--danger{ background:var(--stamp-red); color:var(--card); }
        .btn--sm{ padding:8px 14px; font-size:.72rem; box-shadow:2px 2px 0 var(--ink); }
        .btn--sm:hover{ transform:translate(-1px,-1px); box-shadow:3px 3px 0 var(--ink); }

        .page-header{ padding:36px 0 28px; }
        .page-header__top{ display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:18px; }
        .brand{ font-family:'Fraunces',serif; font-weight:600; font-size:1.05rem; letter-spacing:.01em; }
        .page-header h1{ font-size:clamp(1.9rem, 4vw, 2.6rem); font-weight:600; margin:14px 0 10px; }
        .page-header p{ color:var(--ink-soft); max-width:46ch; margin:0; }

        .grid{ display:grid; grid-template-columns:repeat(auto-fill, minmax(250px,1fr)); gap:22px; margin-top:8px; }
        .card{ position:relative; background:var(--card); border:1px solid var(--rule); border-radius:7px; padding:24px 22px 28px; box-shadow:var(--shadow); transition:transform .18s ease, box-shadow .18s ease; }
        .card:hover{ transform:translateY(-4px); box-shadow:0 20px 40px -16px rgba(43,38,32,.5); }
        .card__category{ margin-bottom:14px; }
        .card h2{ font-size:1.25rem; font-weight:600; line-height:1.25; margin-bottom:4px; }
        .card__author{ font-style:italic; color:var(--ink-soft); font-size:.92rem; margin:0 0 18px; }
        .card__meta{ display:flex; align-items:center; justify-content:space-between; border-top:1px dashed var(--rule); padding-top:14px; margin-bottom:18px; }
        .price-chip{ font-family:'Special Elite',monospace; font-size:.95rem; background:var(--brass-pale); color:var(--brass-dark); padding:4px 10px; border-radius:3px; transform:rotate(-1.5deg); display:inline-block; }
        .qty{ font-size:.82rem; color:var(--ink-soft); }
        .card__actions{ display:flex; gap:10px; }
        .card__hole{ position:absolute; left:50%; bottom:10px; transform:translateX(-50%); width:11px; height:11px; border-radius:50%; background:var(--paper); box-shadow:inset 0 1px 3px rgba(43,38,32,.5), 0 0 0 1px var(--rule); }

        .empty{ text-align:center; border:1.5px dashed var(--rule); border-radius:8px; padding:60px 24px; margin-top:8px; }
        .empty p{ color:var(--ink-soft); margin:0 0 22px; font-size:1.02rem; }

        @media (max-width: 600px){ .wrap{ padding:0 18px 60px; } .page-header__top{ flex-direction:column; align-items:flex-start; } }
        @media (prefers-reduced-motion: reduce){ *{ animation-duration:0.001ms !important; transition-duration:0.001ms !important; } }
    </style>
</head>
<body>

    <div class="shelf-strip" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="wrap">
        <header class="page-header">
            <div class="page-header__top">
                <span class="brand">Athenaeum</span>
                <a class="btn btn--sm" href="/insertdata">+ Add a Title</a>
            </div>
            <span class="stamp stamp--green">Accessions Ledger</span>
            <h1>On the Shelves</h1>
            <p>Every title currently in the collection, with its category, price, and count on hand.</p>
        </header>

        <% if (allbook.length === 0) { %>
            <div class="empty">
                <p>These shelves are bare. Add the first title to start the ledger.</p>
                <a class="btn" href="/insertdata">Add a Title</a>
            </div>
        <% } else { %>
            <div class="grid">
                <% allbook.forEach((element) => { %>
                    <article class="card">
                        <span class="stamp stamp--brass card__category"><%= element.category %></span>
                        <h2><%= element.bookname %></h2>
                        <p class="card__author">by <%= element.author %></p>
                        <div class="card__meta">
                            <span class="price-chip">$<%= element.price %></span>
                            <span class="qty"><%= element.quantity %> in stock</span>
                        </div>
                        <div class="card__actions">
                            <a href="/edit/<%= element._id %>" class="btn btn--ghost btn--sm">Edit</a>
                            <a href="/Delete/<%= element._id %>" class="btn btn--danger btn--sm" onclick="return confirm('Confirm document removal?')">Remove</a>
                        </div>
                        <span class="card__hole" aria-hidden="true"></span>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </div>

</body>
</html>
